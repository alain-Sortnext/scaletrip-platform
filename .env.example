# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scaletrip
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=changeme-minimum-32-chars-required
JWT_EXPIRY=15m
# WARNING: Never set this to true in staging or production
JWT_IGNORE_EXPIRY=false

# ── Services ─────────────────────────────────────────────────
BOOKING_SERVICE_PORT=3001
AUTH_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
GATEWAY_PORT=3000

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=scaletrip-exports-dev
CLOUDWATCH_LOG_GROUP=/scaletrip/platform
SQS_BOOKING_QUEUE_URL=
SQS_DLQ_URL=

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
