{
  "name": "scaletrip-platform",
  "version": "0.8.2",
  "description": "ScaleTrip Cloud backend platform — monorepo",
  "private": true,
  "workspaces": [
    "services/*",
    "gateway",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=services/booking-service\" \"npm run dev --workspace=services/auth-service\"",
    "build": "tsc --build",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.js",
    "migrate": "node scripts/migrate.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "bullmq": "^4.12.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "winston": "^3.10.0",
    "zod": "^3.22.0",
    "bcrypt": "^5.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
